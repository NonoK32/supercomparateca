# Copia este archivo a .env y rellena los valores reales.
# .env está en .gitignore y NUNCA debe subirse al repositorio.

# ---- Base de datos (PostgreSQL) ----
POSTGRES_USER=supercomparateca
POSTGRES_PASSWORD=cambia-esto
POSTGRES_DB=supercomparateca
DATABASE_URL=postgresql://supercomparateca:cambia-esto@db:5432/supercomparateca

# ---- API ----
# Genera uno con: openssl rand -hex 32
JWT_SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- OCR service ----
OCR_SERVICE_URL=http://ocr-service:8001

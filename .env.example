# Copia este archivo a .env y rellena los valores reales.
# .env está en .gitignore y NUNCA debe subirse al repositorio.
# docker-compose lee estas variables.

# ---- Base de datos (PostgreSQL) ----
POSTGRES_USER=supercomparateca
POSTGRES_PASSWORD=cambia-esto
POSTGRES_DB=supercomparateca

# ---- OCR ----
# Idioma de Tesseract (la imagen incluye 'spa').
OCR_LANG=spa

# ---- API ----
# OBLIGATORIO. La API NO arranca con este placeholder: genera uno real con
#   openssl rand -hex 32
JWT_SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Matching por similitud (EPIC 10) ----
# Por encima de UMBRAL_AUTO la línea se asocia sola; entre UMBRAL_SUGERENCIA y
# UMBRAL_AUTO se propone al usuario. Súbelos si ves falsos positivos, bájalos
# si el sistema pregunta demasiado.
UMBRAL_AUTO=0.92
UMBRAL_SUGERENCIA=0.70

# ---- Producción (solo con docker-compose.prod.yml / Traefik) ----
# Dominio real apuntando al servidor y email para Let's Encrypt.
DOMAIN=supercomparateca.example.com
ACME_EMAIL=tu-email@example.com

# CA de ACME. Si se deja vacía se usa la de PRODUCCIÓN de Let's Encrypt.
# Para ENSAYAR el despliegue sin gastar cuota, descomenta la de staging: emite
# certificados que el navegador no reconoce (verás un aviso de seguridad), pero
# el flujo es idéntico y los límites son mucho más altos.
#
# Producción: 5 fallos de validación por hora y 50 certificados por dominio y
# semana. Un DNS mal puesto con reintentos te bloquea durante horas.
#
# ⚠️ Al pasar de staging a producción hay que BORRAR el volumen de certificados,
# o Traefik seguirá sirviendo el de staging:
#     docker compose -f docker-compose.yml -f docker-compose.prod.yml down
#     docker volume rm supercomparateca_letsencrypt
# ACME_CASERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# Nota: docker-compose deriva DATABASE_URL (postgresql+psycopg://…@db:5432/…)
# y OCR_SERVICE_URL (http://ocr-service:8001) a partir de lo anterior.
# Para desarrollo local SIN docker, el api usa SQLite por defecto.
